# Astro DB con Turso (Astro 6 format)
# La integración @astrojs/db detecta automáticamente estas variables
#
# Pasos para configurar (opción web - más fácil):
# 1. Ve a https://turso.tech y crea una cuenta
# 2. Crea una nueva base de datos con nombre: quinta-el-cielo
# 3. Copia la URL y el token desde el dashboard
# 4. Pega los valores abajo
#
# NOTA: Para desarrollo local, comenta estas líneas y Astro DB usará SQLite automáticamente
ASTRO_DB_REMOTE_URL=libsql://your-db-name.turso.io
ASTRO_DB_APP_TOKEN=your_turso_auth_token_here

# JWT Secret (genera uno aleatorio seguro)
# Puedes usar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_secret_key_here

# URL del sitio (cambiar en producción)
SITE_URL=http://localhost:4321
