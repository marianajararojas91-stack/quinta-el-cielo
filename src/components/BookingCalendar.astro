---
// Importaciones de iconos Lucide
import {
    Calendar,
    Users,
    FileText,
    Home,
    Building2,
    CheckCircle2,
} from "lucide-astro";
---

<!-- Formulario de Reservas -->
<div class="max-w-4xl mx-auto">
    <div class="bg-white rounded-2xl shadow-xl p-8">
        <h2 class="text-3xl font-bold text-night mb-6">Reserva tu Estadía</h2>

        <form id="booking-form" class="space-y-6">
            <!-- Selección de Plan -->
            <div>
                <label
                    class="block text-sm font-semibold text-night mb-3 flex items-center gap-2"
                >
                    <Home class="w-4 h-4" />
                    Selecciona tu Plan
                </label>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                    <!-- Opción 1: Planta Baja -->
                    <label class="relative cursor-pointer group">
                        <input
                            type="radio"
                            name="tipo"
                            value="baja"
                            class="peer sr-only"
                            required
                        />
                        <div
                            class="relative p-5 border-2 border-gray-200 rounded-2xl peer-checked:border-[3px] peer-checked:border-black peer-checked:scale-[1.02] transition-all hover:border-gray-400 h-full"
                        >
                            <div
                                class="absolute top-3 right-3 opacity-0 peer-checked:opacity-100 transition-opacity"
                            >
                                <div
                                    class="w-6 h-6 rounded-full bg-black flex items-center justify-center shadow-lg"
                                >
                                    <CheckCircle2 class="w-4 h-4 text-white" />
                                </div>
                            </div>

                            <div
                                class="w-10 h-10 bg-forest/10 rounded-xl flex items-center justify-center mb-3 group-hover:bg-forest/20 transition-colors"
                            >
                                <Home class="w-5 h-5 text-forest" />
                            </div>

                            <h3 class="font-bold text-lg text-night mb-1">
                                Planta Baja
                            </h3>
                            <p class="text-xs text-night/60 mb-3">
                                Paraíso • Fin de semana
                            </p>

                            <div class="flex items-baseline gap-1">
                                <span class="text-2xl font-bold text-forest"
                                    >$5,499</span
                                >
                                <span class="text-xs text-night/50">MXN</span>
                            </div>
                            <p class="text-xs text-night/50 mt-1">6-8 personas</p>
                        </div>
                    </label>

                    <!-- Opción 2: Cabaña Completa -->
                    <label class="relative cursor-pointer group">
                        <input
                            type="radio"
                            name="tipo"
                            value="completa"
                            class="peer sr-only"
                        />
                        <div
                            class="relative p-5 border-2 border-gray-200 rounded-2xl peer-checked:border-[3px] peer-checked:border-black peer-checked:scale-[1.02] transition-all hover:border-gray-400 h-full"
                        >
                            <div
                                class="absolute top-3 right-3 opacity-0 peer-checked:opacity-100 transition-opacity"
                            >
                                <div
                                    class="w-6 h-6 rounded-full bg-black flex items-center justify-center shadow-lg"
                                >
                                    <CheckCircle2 class="w-4 h-4 text-white" />
                                </div>
                            </div>

                            <div
                                class="w-10 h-10 bg-sunset/10 rounded-xl flex items-center justify-center mb-3 group-hover:bg-sunset/20 transition-colors"
                            >
                                <Building2 class="w-5 h-5 text-sunset" />
                            </div>

                            <h3 class="font-bold text-lg text-night mb-1">
                                Cabaña Completa
                            </h3>
                            <p class="text-xs text-night/60 mb-3">
                                Todas • Fin de semana
                            </p>

                            <div class="flex items-baseline gap-1">
                                <span class="text-2xl font-bold text-sunset"
                                    >$8,500</span
                                >
                                <span class="text-xs text-night/50">MXN</span>
                            </div>
                            <p class="text-xs text-night/50 mt-1">15-20 personas</p>
                        </div>
                    </label>

                    <!-- Opción 3: Por Día - Grupos Grandes -->
                    <label class="relative cursor-pointer group">
                        <input
                            type="radio"
                            name="tipo"
                            value="dia-grande"
                            class="peer sr-only"
                        />
                        <div
                            class="relative p-5 border-2 border-gray-200 rounded-2xl peer-checked:border-[3px] peer-checked:border-black peer-checked:scale-[1.02] transition-all hover:border-gray-400 h-full"
                        >
                            <div
                                class="absolute top-3 right-3 opacity-0 peer-checked:opacity-100 transition-opacity"
                            >
                                <div
                                    class="w-6 h-6 rounded-full bg-black flex items-center justify-center shadow-lg"
                                >
                                    <CheckCircle2 class="w-4 h-4 text-white" />
                                </div>
                            </div>

                            <div
                                class="w-10 h-10 bg-forest/10 rounded-xl flex items-center justify-center mb-3 group-hover:bg-forest/20 transition-colors"
                            >
                                <Users class="w-5 h-5 text-forest" />
                            </div>

                            <h3 class="font-bold text-lg text-night mb-1">
                                Por Día
                            </h3>
                            <p class="text-xs text-night/60 mb-3">
                                Grupos grandes
                            </p>

                            <div class="flex items-baseline gap-1">
                                <span class="text-2xl font-bold text-forest"
                                    >$500</span
                                >
                                <span class="text-xs text-night/50">/ día</span>
                            </div>
                            <p class="text-xs text-night/50 mt-1">Mín. 8 personas</p>
                        </div>
                    </label>

                    <!-- Opción 4: Por Día - Grupos Pequeños -->
                    <label class="relative cursor-pointer group">
                        <input
                            type="radio"
                            name="tipo"
                            value="dia-pequeno"
                            class="peer sr-only"
                        />
                        <div
                            class="relative p-5 border-2 border-gray-200 rounded-2xl peer-checked:border-[3px] peer-checked:border-black peer-checked:scale-[1.02] transition-all hover:border-gray-400 h-full"
                        >
                            <div
                                class="absolute top-3 right-3 opacity-0 peer-checked:opacity-100 transition-opacity"
                            >
                                <div
                                    class="w-6 h-6 rounded-full bg-black flex items-center justify-center shadow-lg"
                                >
                                    <CheckCircle2 class="w-4 h-4 text-white" />
                                </div>
                            </div>

                            <div
                                class="w-10 h-10 bg-sunset/10 rounded-xl flex items-center justify-center mb-3 group-hover:bg-sunset/20 transition-colors"
                            >
                                <Users class="w-5 h-5 text-sunset" />
                            </div>

                            <h3 class="font-bold text-lg text-night mb-1">
                                Por Día
                            </h3>
                            <p class="text-xs text-night/60 mb-3">
                                Grupos pequeños
                            </p>

                            <div class="flex items-baseline gap-1">
                                <span class="text-2xl font-bold text-sunset"
                                    >$500</span
                                >
                                <span class="text-xs text-night/50">/ día</span>
                            </div>
                            <p class="text-xs text-night/50 mt-1">Mín. 5 personas • 2 días</p>
                        </div>
                    </label>
                </div>
            </div>

            <!-- Selección de Fechas -->
            <div>
                <label class="block text-sm font-semibold text-night mb-3 flex items-center gap-2">
                    <Calendar class="w-4 h-4" />
                    <span id="date-label">Selecciona tus Fechas</span>
                </label>
                <p id="date-description" class="text-sm text-night/60 mb-4">
                    Selecciona un plan primero
                </p>

                <!-- Selector de fines de semana (planes baja/completa) -->
                <div id="weekend-picker" class="space-y-4 hidden">
                    <!-- Weekend selector will be rendered here -->
                </div>

                <!-- Selector de fechas flexibles (planes por día) -->
                <div id="flexible-picker" class="space-y-4 hidden">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-night/70 mb-2">Fecha de entrada</label>
                            <input
                                type="date"
                                id="flexStartDate"
                                class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-black focus:border-black"
                            />
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-night/70 mb-2">Fecha de salida</label>
                            <input
                                type="date"
                                id="flexEndDate"
                                class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-black focus:border-black"
                            />
                        </div>
                    </div>
                    <p class="text-xs text-night/50 mt-2" id="days-count"></p>
                </div>

                <input type="hidden" id="startDate" name="startDate" required />
                <input type="hidden" id="endDate" name="endDate" required />
            </div>

            <!-- Número de Huéspedes -->
            <div>
                <label
                    for="guests"
                    class="block text-sm font-semibold text-night mb-2"
                >
                    <Users class="w-4 h-4 inline mr-1" />
                    Número de Huéspedes
                </label>
                <input
                    type="number"
                    id="guests"
                    name="guests"
                    min="1"
                    max="20"
                    placeholder="¿Cuántas personas?"
                    class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-forest focus:border-transparent"
                    required
                />
                <p class="text-xs text-night/50 mt-1">Máximo 20 personas</p>
            </div>

            <!-- Notas -->
            <div>
                <label
                    for="notes"
                    class="block text-sm font-semibold text-night mb-2"
                >
                    <FileText class="w-4 h-4 inline mr-1" />
                    Notas o Solicitudes Especiales (Opcional)
                </label>
                <textarea
                    id="notes"
                    name="notes"
                    rows="3"
                    placeholder="¿Alguna solicitud especial?"
                    class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-forest focus:border-transparent resize-none"
                ></textarea>
            </div>

            <!-- Total -->
            <div
                id="price-summary"
                class="hidden bg-black/5 border-2 border-black/10 rounded-2xl p-6"
            >
                <div class="flex justify-between items-center">
                    <div>
                        <p class="text-sm font-semibold text-night/70">
                            Total del Fin de Semana
                        </p>
                        <p class="text-xs text-night/50 mt-1">
                            Viernes a Domingo (3 días, 2 noches)
                        </p>
                    </div>
                    <div class="text-right">
                        <p
                            id="total-price"
                            class="text-4xl font-bold text-black"
                        >
                            $0
                        </p>
                        <p class="text-xs text-night/50">MXN</p>
                    </div>
                </div>
            </div>

            <!-- Error/Success Messages -->
            <div id="booking-message" class="hidden rounded-xl p-4"></div>

            <!-- Submit Button -->
            <div class="pt-4 border-t border-gray-200">
                <button
                    type="submit"
                    id="submit-btn"
                    class="w-full py-5 bg-black text-white rounded-2xl font-bold text-lg hover:shadow-2xl hover:scale-[1.02] transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
                >
                    Confirmar Reserva
                </button>

                <p class="text-xs text-center text-night/50 mt-4">
                    Tu reserva estará pendiente de confirmación. Te
                    contactaremos para finalizar los detalles.
                </p>
            </div>
        </form>
    </div>
</div>

<script>
    // Referencias del DOM
    const form = document.getElementById("booking-form") as HTMLFormElement;
    const submitBtn = document.getElementById(
        "submit-btn",
    ) as HTMLButtonElement;
    const messageDiv = document.getElementById(
        "booking-message",
    ) as HTMLDivElement;
    const priceSummary = document.getElementById(
        "price-summary",
    ) as HTMLDivElement;
    const totalPriceEl = document.getElementById(
        "total-price",
    ) as HTMLParagraphElement;
    const tipoInputs = document.querySelectorAll(
        'input[name="tipo"]',
    ) as NodeListOf<HTMLInputElement>;
    const startDateInput = document.getElementById("startDate") as HTMLInputElement;
    const endDateInput = document.getElementById("endDate") as HTMLInputElement;
    const weekendPicker = document.getElementById("weekend-picker") as HTMLDivElement;
    const flexiblePicker = document.getElementById("flexible-picker") as HTMLDivElement;
    const flexStartDateInput = document.getElementById("flexStartDate") as HTMLInputElement;
    const flexEndDateInput = document.getElementById("flexEndDate") as HTMLInputElement;
    const daysCountEl = document.getElementById("days-count") as HTMLParagraphElement;
    const dateLabel = document.getElementById("date-label") as HTMLSpanElement;
    const dateDescription = document.getElementById("date-description") as HTMLParagraphElement;

    // Variables de estado
    let selectedWeekend: { friday: Date; sunday: Date } | null = null;
    let currentMonth = new Date();
    let occupiedDates: string[] = [];
    let currentPlanType: string | null = null;

    // Configurar fecha mínima (hoy)
    const today = new Date().toISOString().split('T')[0];
    flexStartDateInput.min = today;
    flexEndDateInput.min = today;

    // Obtener fechas ocupadas desde la API
    async function fetchOccupiedDates() {
        try {
            const response = await fetch("/api/bookings/available");
            const data = await response.json();
            occupiedDates = data.occupiedDates || [];
            if (currentPlanType === 'baja' || currentPlanType === 'completa') {
                renderWeekendPicker();
            }
        } catch (error) {
            console.error("Error fetching occupied dates:", error);
            if (currentPlanType === 'baja' || currentPlanType === 'completa') {
                renderWeekendPicker();
            }
        }
    }

    // Verificar si una fecha está ocupada
    function isDateOccupied(date: Date): boolean {
        const dateStr = date.toISOString().split('T')[0];
        return occupiedDates.includes(dateStr);
    }

    // Obtener todos los fines de semana del mes
    function getWeekendsInMonth(date: Date): Array<{ friday: Date; sunday: Date; available: boolean }> {
        const year = date.getFullYear();
        const month = date.getMonth();
        const weekends: Array<{ friday: Date; sunday: Date; available: boolean }> = [];

        const firstDay = new Date(year, month, 1);
        const lastDay = new Date(year, month + 1, 0);

        for (let day = firstDay; day <= lastDay; day.setDate(day.getDate() + 1)) {
            if (day.getDay() === 5) { // Friday
                const friday = new Date(day);
                const saturday = new Date(friday);
                saturday.setDate(saturday.getDate() + 1);
                const sunday = new Date(friday);
                sunday.setDate(sunday.getDate() + 2);

                const today = new Date();
                today.setHours(0, 0, 0, 0);

                const available = friday >= today &&
                    !isDateOccupied(friday) &&
                    !isDateOccupied(saturday) &&
                    !isDateOccupied(sunday);

                weekends.push({ friday: new Date(friday), sunday: new Date(sunday), available });
            }
        }

        return weekends;
    }

    // Formatear fecha para mostrar
    function formatDate(date: Date, format: string): string {
        const months = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
        const days = ['Dom', 'Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb'];

        if (format === 'month-year') {
            return `${months[date.getMonth()]} ${date.getFullYear()}`;
        } else if (format === 'short') {
            return `${days[date.getDay()]} ${date.getDate()} ${months[date.getMonth()].slice(0, 3)}`;
        }
        return `${date.getDate()} de ${months[date.getMonth()]}`;
    }

    // Renderizar selector de fines de semana
    function renderWeekendPicker() {
        const weekends = getWeekendsInMonth(currentMonth);

        weekendPicker.innerHTML = `
            <div class="bg-white rounded-2xl border-2 border-gray-200 overflow-hidden">
                <!-- Header -->
                <div class="flex items-center justify-between p-4 bg-gray-50 border-b border-gray-200">
                    <button type="button" id="prev-month" class="p-2 hover:bg-gray-200 rounded-lg transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                        </svg>
                    </button>
                    <h3 class="text-lg font-bold text-night capitalize">
                        ${formatDate(currentMonth, 'month-year')}
                    </h3>
                    <button type="button" id="next-month" class="p-2 hover:bg-gray-200 rounded-lg transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </button>
                </div>

                <!-- Weekends List -->
                <div class="p-4 space-y-3">
                    ${weekends.length === 0 ? `
                        <p class="text-center text-night/60 py-8">
                            No hay fines de semana disponibles en este mes
                        </p>
                    ` : weekends.map((weekend, index) => {
                        const isSelected = selectedWeekend &&
                            selectedWeekend.friday.getTime() === weekend.friday.getTime();

                        return `
                            <button
                                type="button"
                                data-weekend-index="${index}"
                                class="w-full p-4 rounded-xl border-2 text-left transition-all ${
                                    isSelected
                                        ? "border-black bg-black text-white"
                                        : weekend.available
                                        ? "border-gray-200 hover:border-black"
                                        : "border-gray-200 bg-gray-50 opacity-50 cursor-not-allowed"
                                }"
                                ${!weekend.available ? 'disabled' : ''}
                            >
                                <div class="flex items-center justify-between">
                                    <div class="flex-1">
                                        <div class="flex items-center gap-2 mb-1">
                                            <svg class="w-4 h-4 ${isSelected ? 'text-white' : weekend.available ? 'text-black' : 'text-gray-400'}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                            </svg>
                                            <span class="font-semibold">
                                                ${weekend.friday.getDate()} - ${weekend.sunday.getDate()} de ${formatDate(weekend.friday, 'date')}
                                            </span>
                                        </div>
                                        <p class="text-sm ${isSelected ? 'text-white/80' : 'text-night/60'}">
                                            ${formatDate(weekend.friday, 'short')} (4:00 PM) → ${formatDate(weekend.sunday, 'short')} (2:00 PM)
                                        </p>
                                    </div>
                                    ${!weekend.available ? `
                                        <span class="text-xs font-semibold text-red-600 bg-red-100 px-3 py-1 rounded-full">
                                            Ocupado
                                        </span>
                                    ` : ''}
                                </div>
                            </button>
                        `;
                    }).join('')}
                </div>
            </div>
        `;

        // Add event listeners
        const prevBtn = document.getElementById('prev-month');
        const nextBtn = document.getElementById('next-month');

        prevBtn?.addEventListener('click', () => {
            currentMonth = new Date(currentMonth.getFullYear(), currentMonth.getMonth() - 1, 1);
            renderWeekendPicker();
        });

        nextBtn?.addEventListener('click', () => {
            currentMonth = new Date(currentMonth.getFullYear(), currentMonth.getMonth() + 1, 1);
            renderWeekendPicker();
        });

        // Weekend selection
        weekends.forEach((weekend, index) => {
            if (weekend.available) {
                const btn = weekendPicker.querySelector(`[data-weekend-index="${index}"]`);
                btn?.addEventListener('click', () => {
                    selectedWeekend = weekend;
                    startDateInput.value = weekend.friday.toISOString().split('T')[0];
                    endDateInput.value = weekend.sunday.toISOString().split('T')[0];
                    renderWeekendPicker();
                    updatePrice();
                });
            }
        });
    }

    // Alternar entre selectores de fechas según el plan
    function switchDatePicker(tipo: string) {
        currentPlanType = tipo;

        // Reset selections
        selectedWeekend = null;
        startDateInput.value = '';
        endDateInput.value = '';
        flexStartDateInput.value = '';
        flexEndDateInput.value = '';
        priceSummary.classList.add("hidden");

        if (tipo === 'baja' || tipo === 'completa') {
            // Fin de semana
            dateLabel.textContent = 'Selecciona tu Fin de Semana';
            dateDescription.textContent = 'Solo aceptamos reservas de fin de semana completo (Viernes 4PM a Domingo 2PM)';
            weekendPicker.classList.remove('hidden');
            flexiblePicker.classList.add('hidden');
            fetchOccupiedDates();
        } else if (tipo === 'dia-grande' || tipo === 'dia-pequeno') {
            // Por día
            dateLabel.textContent = 'Selecciona tus Fechas';
            dateDescription.textContent = tipo === 'dia-pequeno'
                ? 'Mínimo 2 días de estadía. Solo viernes, sábados o domingos.'
                : 'Solo viernes, sábados o domingos.';
            weekendPicker.classList.add('hidden');
            flexiblePicker.classList.remove('hidden');
        }
    }

    // Validar que sea fin de semana (vie/sáb/dom)
    function isWeekendDay(day: number): boolean {
        return day === 5 || day === 6 || day === 0; // Viernes, Sábado, Domingo
    }

    // Validar fecha individual
    function validateDateInput(input: HTMLInputElement, isStart: boolean) {
        if (!input.value) return;

        // Parse date from YYYY-MM-DD format to avoid timezone issues
        const [year, month, day] = input.value.split('-').map(Number);
        const selectedDate = new Date(year, month - 1, day);
        const dayOfWeek = selectedDate.getDay();

        console.log('Fecha seleccionada:', input.value, 'Día de la semana:', dayOfWeek, ['Dom', 'Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb'][dayOfWeek]);

        if (!isWeekendDay(dayOfWeek)) {
            const dayName = isStart ? "entrada" : "salida";
            showMessage(`La fecha de ${dayName} debe ser viernes, sábado o domingo`, true);
            input.value = '';
            daysCountEl.textContent = '';
            return;
        }

        // Si ambas fechas están llenas, calcular días
        calculateFlexibleDays();
    }

    // Calcular días y actualizar precio para fechas flexibles
    function calculateFlexibleDays() {
        // Solo calcular si ambas fechas están llenas
        if (!flexStartDateInput.value || !flexEndDateInput.value) {
            daysCountEl.textContent = '';
            return;
        }

        // Parse dates to avoid timezone issues
        const [startYear, startMonth, startDay] = flexStartDateInput.value.split('-').map(Number);
        const [endYear, endMonth, endDay] = flexEndDateInput.value.split('-').map(Number);
        const start = new Date(startYear, startMonth - 1, startDay);
        const end = new Date(endYear, endMonth - 1, endDay);

        // Validar que la fecha de salida sea posterior a la de entrada
        if (end <= start) {
            showMessage("La fecha de salida debe ser posterior a la fecha de entrada", true);
            daysCountEl.textContent = '';
            return;
        }

        // Calcular días INCLUYENDO día de entrada y salida
        // Ejemplo: Viernes 16 a Domingo 18 = 3 días (Vie, Sáb, Dom)
        const days = Math.ceil((end.getTime() - start.getTime()) / (1000 * 60 * 60 * 24)) + 1;
        daysCountEl.textContent = `${days} día${days > 1 ? 's' : ''} de estadía`;

        // Actualizar campos ocultos
        startDateInput.value = flexStartDateInput.value;
        endDateInput.value = flexEndDateInput.value;

        // Create fake weekend object for price calculation
        selectedWeekend = {
            friday: start,
            sunday: end
        };

        updatePrice();
    }

    // Inicializar carga de fechas ocupadas
    fetchOccupiedDates();

    // Escuchar cambios en fechas flexibles
    flexStartDateInput.addEventListener('change', () => validateDateInput(flexStartDateInput, true));
    flexEndDateInput.addEventListener('change', () => validateDateInput(flexEndDateInput, false));

    // Escuchar cambio de plan
    tipoInputs.forEach((input) => {
        input.addEventListener("change", () => {
            switchDatePicker(input.value);
            updatePrice();
        });
    });

    // Actualizar precio según plan y fechas seleccionadas
    function updatePrice() {
        const selectedTipo = document.querySelector(
            'input[name="tipo"]:checked',
        ) as HTMLInputElement;

        if (selectedTipo && selectedWeekend) {
            const prices: { [key: string]: number } = {
                baja: 5499,
                completa: 8500,
                'dia-grande': 500,
                'dia-pequeno': 500,
            };

            const basePrice = prices[selectedTipo.value];
            let finalPrice = basePrice;
            let priceLabel = "Total del Fin de Semana";
            let priceDescription = "Viernes a Domingo (3 días, 2 noches)";

            // Para opciones por día, calcular según días seleccionados
            if (selectedTipo.value === 'dia-grande' || selectedTipo.value === 'dia-pequeno') {
                const startDate = new Date(selectedWeekend.friday);
                const endDate = new Date(selectedWeekend.sunday);
                // Calcular días INCLUYENDO el día de entrada y salida
                const days = Math.ceil((endDate.getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24)) + 1;

                finalPrice = basePrice * days;
                priceLabel = "Total por Estadía";
                priceDescription = `${days} día${days > 1 ? 's' : ''}`;
            }

            totalPriceEl.textContent = `$${finalPrice.toLocaleString("es-MX")}`;

            // Actualizar labels dinámicamente
            const summaryLabel = document.querySelector('#price-summary p.text-sm') as HTMLParagraphElement;
            const summaryDescription = document.querySelector('#price-summary p.text-xs') as HTMLParagraphElement;

            if (summaryLabel) summaryLabel.textContent = priceLabel;
            if (summaryDescription) summaryDescription.textContent = priceDescription;

            priceSummary.classList.remove("hidden");
        }
    }

    function showMessage(message: string, isError: boolean = false) {
        messageDiv.textContent = message;
        messageDiv.className = `rounded-xl p-4 ${isError ? "bg-red-100 text-red-800" : "bg-green-100 text-green-800"}`;
        messageDiv.classList.remove("hidden");
    }

    function hideMessage() {
        messageDiv.classList.add("hidden");
    }

    form.addEventListener("submit", async (e) => {
        e.preventDefault();
        hideMessage();

        const formData = new FormData(form);
        const tipo = formData.get("tipo") as string;
        const guests = parseInt(formData.get("guests") as string);

        // Validaciones por tipo de plan
        if (tipo === 'dia-grande' && guests < 8) {
            showMessage("Para el plan 'Por Día - Grupos Grandes' se requieren mínimo 8 personas", true);
            return;
        }

        if (tipo === 'dia-pequeno' && guests < 5) {
            showMessage("Para el plan 'Por Día - Grupos Pequeños' se requieren mínimo 5 personas", true);
            return;
        }

        if (tipo === 'dia-pequeno' && selectedWeekend) {
            const startDate = new Date(selectedWeekend.friday);
            const endDate = new Date(selectedWeekend.sunday);
            const days = Math.ceil((endDate.getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24));

            if (days < 2) {
                showMessage("Para el plan 'Por Día - Grupos Pequeños' se requiere mínimo 2 días de estadía", true);
                return;
            }
        }

        submitBtn.disabled = true;
        submitBtn.textContent = "Procesando...";

        const data = {
            tipo: tipo,
            startDate: formData.get("startDate"),
            endDate: formData.get("endDate"),
            guests: guests,
            notes: formData.get("notes") || "",
        };

        try {
            const response = await fetch("/api/bookings/create", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                },
                body: JSON.stringify(data),
            });

            const result = await response.json();

            if (response.ok) {
                showMessage(
                    "¡Reserva creada exitosamente! Revisa tu correo para la confirmación.",
                    false,
                );
                form.reset();
                priceSummary.classList.add("hidden");

                // Redirect to mis-reservas after 2 seconds
                setTimeout(() => {
                    window.location.href = "/mis-reservas";
                }, 2000);
            } else {
                showMessage(result.error || "Error al crear la reserva", true);
            }
        } catch (error) {
            showMessage("Error al conectar con el servidor", true);
        } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = "Confirmar Reserva";
        }
    });
</script>
