---
const images = [
    '/images/cafe.jpg',
    '/images/CCielo.jpg',
    '/images/CEden.jpg',
    '/images/CNubes.jpg',
    '/images/Cocina.jpg',
    '/images/Vista1.jpg',
    '/images/QC.jpg',
    '/images/Personas.jpg'
];
---

<section id="galeria" class="py-20 md:py-32 bg-bone">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="text-center mb-16">
            <span class="text-sm font-semibold text-sunset uppercase tracking-wider">Galería</span>
            <h2 class="mt-4 text-4xl md:text-5xl font-bold text-night">
                Descubre la belleza de las alturas
            </h2>
        </div>

        <!-- Gallery Grid -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            {images.map((image, index) => (
                <div class="relative aspect-square overflow-hidden rounded-xl group cursor-pointer">
                    <img
                        src={image}
                        alt={`Vista ${index + 1} de Quinta El Cielo`}
                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                        loading="lazy"
                    />
                    <div class="absolute inset-0 bg-night/0 group-hover:bg-night/30 transition-colors duration-300"></div>
                </div>
            ))}
        </div>
    </div>
</section>