---
import { Mountain, Phone, Mail, Instagram, Facebook, Music2 as Tiktok } from "lucide-astro";
---

<footer class="bg-night text-bone">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
            <!-- Brand -->
            <div class="col-span-1 md:col-span-2">
                <div class="flex items-center gap-3 mb-4">
                    <img
                        src="/logo.png"
                        alt="Quinta El Cielo Logo"
                        class="w-24 h-24 object-contain"
                    />
                    <span class="text-2xl font-bold">Quinta El Cielo</span>
                </div>
                <p class="text-bone/70 mb-4">
                    Tu refugio exclusivo en las alturas de la Sierra de Arteaga.
                    Donde el cielo se toca con las manos.
                </p>
                <div class="flex gap-4">
                    <a
                        href="https://www.instagram.com/elcielocabanas.mx?igsh=d3FoOHJoam84Nm1r"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-10 h-10 bg-bone/10 hover:bg-sunset rounded-full flex items-center justify-center transition-colors"
                        aria-label="Instagram"
                    >
                        <Instagram class="w-5 h-5" />
                    </a>
                    <a
                        href="https://www.facebook.com/profile.php?id=61569230587551"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-10 h-10 bg-bone/10 hover:bg-sunset rounded-full flex items-center justify-center transition-colors"
                        aria-label="Facebook"
                    >
                        <Facebook class="w-5 h-5" />
                    </a>
                    <a
                        href="https://www.tiktok.com/@cabana.elcielo"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-10 h-10 bg-bone/10 hover:bg-sunset rounded-full flex items-center justify-center transition-colors"
                        aria-label="TikTok"
                    >
                        <Tiktok class="w-5 h-5" />
                    </a>
                </div>
            </div>

            <!-- Links -->
            <div>
                <h3 class="font-semibold mb-4 text-sunset">Enlaces</h3>
                <ul class="space-y-2">
                    <li>
                        <a
                            href="#cabana"
                            class="text-bone/70 hover:text-sunset transition-colors"
                            >La Cabaña</a
                        >
                    </li>
                    <li>
                        <a
                            href="/#amenidades"
                            class="text-bone/70 hover:text-sunset transition-colors"
                            >Amenidades</a
                        >
                    </li>
                    <li>
                        <a
                            href="/#galeria"
                            class="text-bone/70 hover:text-sunset transition-colors"
                            >Galería</a
                        >
                    </li>
                    <li>
                        <a
                            href="/#valoraciones"
                            class="text-bone/70 hover:text-sunset transition-colors"
                            >Valoraciones</a
                        >
                    </li>
                    <li>
                        <a
                            href="/reservar"
                            class="text-bone/70 hover:text-sunset transition-colors"
                            >Reservar</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Contact -->
            <div>
                <h3 class="font-semibold mb-4 text-sunset">Contacto</h3>
                <ul class="space-y-3">
                    <li class="flex items-center gap-2 text-bone/70">
                        <Phone class="w-4 h-4" />
                        <a
                            href="tel:+528110000000"
                            class="hover:text-sunset transition-colors"
                        >
                            +52 811 000 0000
                        </a>
                    </li>
                    <li class="flex items-center gap-2 text-bone/70">
                        <Mail class="w-4 h-4" />
                        <a
                            href="mailto:elcielocabana.oficial@gmail.com"
                            class="hover:text-sunset transition-colors"
                        >
                            elcielocabana.oficial@gmail.com
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Bottom -->
        <div class="pt-8 border-t border-bone/10">
            <div
                class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-bone/60"
            >
                <p>
                    © 2026 Quinta El Cielo. Todos los derechos
                    reservados.
                </p>
                <div class="flex gap-6">
                    <a href="#" class="hover:text-sunset transition-colors"
                        >Privacidad</a
                    >
                    <a href="#" class="hover:text-sunset transition-colors"
                        >Términos</a
                    >
                </div>
            </div>
        </div>
    </div>
</footer>
