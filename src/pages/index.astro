---
// Importaciones de componentes de la landing page
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Hero from "../components/sections/Hero.astro";
import Features from "../components/sections/Features.astro";
import Amenities from "../components/sections/Amenities.astro";
import Pricing from "../components/sections/Pricing.astro";
import Gallery from "../components/sections/Gallery.astro";
import Reviews from "../components/sections/Reviews.astro";
import Location from "../components/sections/Location.astro";
import Footer from "../components/Footer.astro";
---

<!-- Landing Page de Quinta El Cielo -->
<Layout title="Quinta El Cielo - Donde el cielo se toca con las manos">
    <Navigation slot="nav" />

    <!-- Secciones principales -->
    <Hero />
    <Features />
    <Amenities />
    <Pricing />
    <Gallery />
    <Reviews />
    <Location />

    <!-- Booking Section -->
    <section id="reservar" class="py-20 md:py-32 bg-bone">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <span
                class="text-sm font-semibold text-sunset uppercase tracking-wider"
                >Reserva tu Experiencia</span
            >
            <h2 class="mt-4 text-4xl md:text-5xl font-bold text-night mb-6">
                Comienza tu aventura en las alturas
            </h2>
            <p class="text-lg text-night/70 mb-8">
                Reserva tu estadía en Quinta El Cielo y vive una experiencia
                única a 3,550m sobre el nivel del mar.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a
                    href="/reservar"
                    class="px-8 py-4 bg-black text-white rounded-full font-bold hover:shadow-xl hover:scale-105 transition-all duration-300"
                >
                    Reservar Ahora
                </a>
                <a
                    href="#precios"
                    class="px-8 py-4 bg-white text-night rounded-full font-semibold border-2 border-black hover:bg-black hover:text-white transition-colors"
                >
                    Ver Precios
                </a>
            </div>
        </div>
    </section>

    <Footer slot="footer" />
</Layout>
